// variant-picker.js ka basic logic:
// Jab customer variant select karta hai:

onVariantChange(selectedVariant) {
  // 1. Price update karo
  updatePrice(selectedVariant.price);
  
  // 2. Image change karo (color variant = different image)
  updateMedia(selectedVariant.featured_image);
  
  // 3. Availability check karo
  if (!selectedVariant.available) {
    disableAddToCart(); // "Sold Out" dikhao
  }
  
  // 4. URL update karo (without page reload)
  updateURL(selectedVariant.id);
}
